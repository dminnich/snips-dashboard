# Server Configuration
# PORT=3000
# DATA_DIR=/data

# Basic Authentication (optional)
# Set AUTH_ENABLED=true to require authentication
# Leave AUTH_ENABLED=false or unset for open access (LAN-only recommended)
AUTH_ENABLED=false
AUTH_USERNAME=admin
AUTH_PASSWORD=changeme

# This project is container-only. Always run via Docker / Podman:
#
#   docker compose up -d                    # start production dashboard
#   docker compose --profile dev up dev     # start dev server with hot-reload
#   docker compose --profile test run --rm test
#
# Do NOT run `npm`, `node`, `vite`, or `vitest` on the host.
# See AGENTS.md and README.md for the full container workflow.
